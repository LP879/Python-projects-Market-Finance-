# ============================================
# 1. Black-Scholes-Merton Vanilla Pricer
# ============================================

# 1.1 Preliminary functions

def N(x):
    return norm.cdf(x)

def dN(x):
    return norm.pdf(x)


# 1.2 Black-Scholes-Merton formulas

def d1(S0, K, r, q, T, sigma):
    return (np.log(S0 / K) + (r - q + 0.5 * sigma**2) * T) / (sigma * np.sqrt(T))

def d2(S0, K, r, q, T, sigma):
    return d1(S0, K, r, q, T, sigma) - sigma * np.sqrt(T)

def BSM_call(S0, K, r, q, T, sigma):
    d1_val = d1(S0, K, r, q, T, sigma)
    d2_val = d2(S0, K, r, q, T, sigma)
    return S0 * np.exp(-q * T) * N(d1_val) - K * np.exp(-r * T) * N(d2_val)

def BSM_put(S0, K, r, q, T, sigma):
    call_price = BSM_call(S0, K, r, q, T, sigma)
    return call_price - (S0 * np.exp(-q * T) - K * np.exp(-r * T))


# ============================================
# 1.2 Bonus – Greeks
# ============================================

def Delta_call(S0, K, r, q, T, sigma):
    return np.exp(-q * T) * N(d1(S0, K, r, q, T, sigma))

def Delta_put(S0, K, r, q, T, sigma):
    return Delta_call(S0, K, r, q, T, sigma) - np.exp(-q * T)

def Gamma(S0, K, r, q, T, sigma):
    d1_val = d1(S0, K, r, q, T, sigma)
    return (dN(d1_val) * np.exp(-q * T)) / (S0 * sigma * np.sqrt(T))

def Vega(S0, K, r, q, T, sigma):
    d1_val = d1(S0, K, r, q, T, sigma)
    return S0 * np.exp(-q * T) * dN(d1_val) * np.sqrt(T)

def Theta_call_daily(S0, K, r, q, T, sigma):
    d1_val = d1(S0, K, r, q, T, sigma)
    d2_val = d2(S0, K, r, q, T, sigma)
    theta = (
        (-S0 * sigma * np.exp(-q * T) * dN(d1_val)) / (2 * np.sqrt(T))
        - r * K * np.exp(-r * T) * N(d2_val)
        + q * S0 * np.exp(-q * T) * N(d1_val)
    )
    return theta / 252

def Theta_put_daily(S0, K, r, q, T, sigma):
    d1_val = d1(S0, K, r, q, T, sigma)
    d2_val = d2(S0, K, r, q, T, sigma)
    theta = (
        (-S0 * sigma * np.exp(-q * T) * dN(d1_val)) / (2 * np.sqrt(T))
        + r * K * np.exp(-r * T) * N(-d2_val)
        - q * S0 * np.exp(-q * T) * N(-d1_val)
    )
    return theta / 252

def rho_call(S0, K, r, q, T, sigma):
    return K * T * np.exp(-r * T) * N(d2(S0, K, r, q, T, sigma))

def rho_put(S0, K, r, q, T, sigma):
    return -K * T * np.exp(-r * T) * N(-d2(S0, K, r, q, T, sigma))


