# ============================================
# 2. Implied Volatility – Newton-Raphson
# ============================================

def Newton_Raphson_volatility(S0, K, r, q, T, call_mkt_price,
                              threshold=1e-6, max_iter=100):

    sigma = max(
        np.sqrt((2 * abs(np.log(S0 / K) + (r - q) * T)) / T),
        1e-4
    )

    for _ in range(max_iter):
        price_diff = BSM_call(S0, K, r, q, T, sigma) - call_mkt_price

        if abs(price_diff) < threshold:
            return sigma

        vega = Vega(S0, K, r, q, T, sigma)

        if vega < 1e-8:
            break

        sigma = max(sigma - price_diff / vega, 1e-4)

    return sigma


